# ==========================================
# PIZZARIA PRINT AGENT - CONFIGURAÇÃO
# ==========================================

# URL do backend (cloud)
BACKEND_URL=https://order-print-1.preview.emergentagent.com

# API Key do Print Agent 
# Obtenha em: Admin > Definições > Print Agent
API_KEY=SUA_API_KEY_AQUI

# Intervalo de verificação (segundos)
POLL_INTERVAL=3

# Máximo de tentativas por impressão
MAX_RETRIES=3

# Timeout de conexão com impressora (segundos)
PRINTER_TIMEOUT=10
